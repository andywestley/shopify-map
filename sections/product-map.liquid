{%- style -%}
  .product-map-section {
    padding: 40px 20px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: var(--font-body-family);
  }

  .map-container-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    background: #fdfdfd;
    border: 1px solid #eee;
  }

  #product-map {
    height: 600px;
    width: 100%;
    z-index: 1;
  }

  .map-controls {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .map-search-input {
    flex-grow: 1;
    padding: 12px 20px;
    border-radius: 30px;
    border: 1px solid #ddd;
    outline: none;
    transition: box-shadow 0.3s ease;
  }

  .map-search-input:focus {
    box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
  }

  .map-btn {
    padding: 12px 24px;
    border-radius: 30px;
    border: none;
    background: #000;
    color: #fff;
    cursor: pointer;
    font-weight: 600;
    transition: transform 0.2s ease, background 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .map-btn:hover {
    background: #333;
    transform: translateY(-2px);
  }

  .map-btn:active {
    transform: translateY(0);
  }

  .map-btn.secondary {
    background: #f0f0f0;
    color: #000;
  }

  .map-btn.secondary:hover {
    background: #e5e5e5;
  }

  .leaflet-popup-content-wrapper {
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
  }

  .leaflet-popup-content {
    margin: 0;
    width: 220px !important;
  }

  .map-popup {
    display: flex;
    flex-direction: column;
  }

  .map-popup-img {
    width: 100%;
    height: 120px;
    object-fit: cover;
  }

  .map-popup-info {
    padding: 15px;
  }

  .map-popup-title {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 700;
  }

  .map-popup-link {
    color: #000;
    text-decoration: underline;
    font-size: 14px;
    font-weight: 600;
  }

  @media screen and (max-width: 768px) {
    #product-map {
      height: 400px;
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<div class="product-map-section">
  <div class="section-header center">
    <h2>{{ section.settings.title }}</h2>
  </div>

  <div class="map-controls">
    <input type="text" id="map-location-search" class="map-search-input" placeholder="Enter a city or address...">
    <button id="map-search-btn" class="map-btn">Search</button>
    <button id="map-geo-btn" class="map-btn secondary">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z" stroke="currentColor" stroke-width="2"/><circle cx="10" cy="10" r="3" fill="currentColor"/></svg>
      Near Me
    </button>
  </div>

  <div class="map-container-wrapper">
    <div id="product-map"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mapElement = document.getElementById('product-map');
    if (!mapElement) return;

    // Initialize Map
    const map = L.map('product-map').setView([0, 0], 2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    const markers = L.featureGroup().addTo(map);
    const userLocationMarker = L.layerGroup().addTo(map);

    // Fetch Products
    async function loadProducts() {
      try {
        let apiUrl = '/search?view=product-map-api&type=product';
        {% if section.settings.collection != blank %}
          apiUrl += '&collection={{ section.settings.collection.handle }}';
        {% else %}
          apiUrl += '&q=*';
        {% endif %}
        
        const response = await fetch(apiUrl);
        const data = await response.json();
        const products = data.products || data;
        
        products.forEach(product => {
          if (product.location) {
            const [lat, lng] = product.location.split(',').map(n => parseFloat(n.trim()));
            if (!isNaN(lat) && !isNaN(lng)) {
              const marker = L.marker([lat, lng]).addTo(markers);
              const popupContent = `
                <div class="map-popup">
                  ${product.image ? `<img src="${product.image}" class="map-popup-img">` : ''}
                  <div class="map-popup-info">
                    <h3 class="map-popup-title">${product.title}</h3>
                    <a href="${product.url}" class="map-popup-link">View Product</a>
                  </div>
                </div>
              `;
              marker.bindPopup(popupContent);
            }
          }
        });

        if (markers.getLayers().length > 0) {
          map.fitBounds(markers.getBounds(), { padding: [50, 50] });
        }
      } catch (error) {
        console.error('Failed to load products for map:', error);
      }
    }

    // nominatim Search
    async function searchLocation(query) {
      if (!query) return;
      try {
        const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`);
        const data = await response.json();
        if (data.length > 0) {
          const loc = data[0];
          map.setView([loc.lat, loc.lon], 12);
        }
      } catch (error) {
        console.error('Search error:', error);
      }
    }

    // Geolocation
    function findMe() {
      if (!navigator.geolocation) return alert('Geolocation not supported');
      
      navigator.geolocation.getCurrentPosition(position => {
        const { latitude, longitude } = position.coords;
        userLocationMarker.clearLayers();
        L.circleMarker([latitude, longitude], {
          radius: 8,
          fillColor: "#3388ff",
          color: "#fff",
          weight: 2,
          opacity: 1,
          fillOpacity: 0.8
        }).addTo(userLocationMarker);
        
        map.setView([latitude, longitude], 12);
      }, () => {
        alert('Unable to retrieve your location');
      });
    }

    // Event Listeners
    document.getElementById('map-search-btn').addEventListener('click', () => {
      searchLocation(document.getElementById('map-location-search').value);
    });

    document.getElementById('map-location-search').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') searchLocation(e.target.value);
    });

    document.getElementById('map-geo-btn').addEventListener('click', findMe);

    loadProducts();
  });
</script>

{% schema %}
{
  "name": "Product Map",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Global Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Filter by Collection",
      "info": "Leave blank to show all products with locations."
    }
  ],
  "presets": [
    {
      "name": "Product Map"
    }
  ]
}
{% endschema %}
