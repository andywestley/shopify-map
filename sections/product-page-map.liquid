{%- liquid
  assign location = product.metafields.custom.location
-%}

{%- if location != blank -%}
  {%- style -%}
    .product-page-map-section {
      padding: 40px 0;
      width: 100%;
    }

    .product-page-map-container {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e8e8e8;
      height: 300px;
    }

    #single-product-map {
      height: 100%;
      width: 100%;
    }

    .product-map-label {
      font-weight: 600;
      margin-bottom: 10px;
      display: block;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 0;
    }
  {%- endstyle -%}

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <div class="product-page-map-section page-width">
    <h3 class="product-map-label">{{ section.settings.label | default: 'Product Location' }}</h3>
    <div class="product-page-map-container" role="region" aria-label="Map showing origin location for {{ product.title | escape }}">
      <div id="single-product-map"></div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const mapElement = document.getElementById('single-product-map');
      if (!mapElement) return;

      const currentProductLocation = {{ location | json }};
      const currentProductId = {{ product.id | json }};
      if (!currentProductLocation) return;

      const [initLat, initLng] = currentProductLocation.split(',').map(n => parseFloat(n.trim()));
      if (isNaN(initLat) || isNaN(initLng)) return;

      const map = L.map('single-product-map', {
        zoomControl: true,
        scrollWheelZoom: false
      }).setView([initLat, initLng], 13);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      const markers = L.layerGroup().addTo(map);

      async function loadAllMarkers() {
        try {
          const response = await fetch('/search?view=product-map-api&type=product&q=*');
          const data = await response.json();
          const products = data.products || data;

          products.forEach(product => {
            if (product.location) {
              const [lat, lng] = product.location.split(',').map(n => parseFloat(n.trim()));
              if (!isNaN(lat) && !isNaN(lng)) {
                const isCurrent = product.id === currentProductId;
                const marker = L.marker([lat, lng], {
                  alt: product.title,
                  opacity: isCurrent ? 1 : 0.7
                }).addTo(markers);

                const popupContent = `
                  <div style="min-width: 150px;">
                    <h4 style="margin: 0 0 5px 0; font-size: 14px;">${product.title}</h4>
                    <a href="${product.url}" style="font-size: 12px; color: #000; font-weight: 600;">View Product</a>
                  </div>
                `;
                marker.bindPopup(popupContent);
                
                if (isCurrent) {
                  marker.openPopup();
                }
              }
            }
          });
        } catch (error) {
          console.error('Failed to load extra markers:', error);
        }
      }

      loadAllMarkers();
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Single Product Map",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Origin Location"
    }
  ],
  "presets": [
    {
      "name": "Single Product Map"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
