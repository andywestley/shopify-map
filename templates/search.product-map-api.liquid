{% layout none %}
{%- liquid
  assign collection_handle = nil
  if canonical_url contains 'collection='
    assign collection_handle = canonical_url | split: 'collection=' | last | split: '&' | first
  endif
  assign collection = collections[collection_handle]
-%}

{%- if collection.handle != blank -%}
  {%- paginate collection.products by 250 -%}
    [
      {%- assign first_item = true -%}
      {%- for item in collection.products -%}
        {%- assign location = item.metafields.custom.location.value | default: item.metafields.custom.location -%}
        {%- if location != blank -%}
          {%- unless first_item -%},{%- endunless -%}
          {
            "id": {{ item.id | json }},
            "title": {{ item.title | json }},
            "url": {{ item.url | json }},
            "image": {{ item.featured_image | img_url: 'medium' | json }},
            "location": {{ location | json }}
          }
          {%- assign first_item = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  {%- endpaginate -%}
{%- else -%}
  {%- paginate search.results by 250 -%}
    [
      {%- assign first_item = true -%}
      {%- for item in search.results -%}
        {%- if item.object_type != 'product' -%}{%- continue -%}{%- endif -%}
        {%- assign location = item.metafields.custom.location.value | default: item.metafields.custom.location -%}
        {%- if location != blank -%}
          {%- unless first_item -%},{%- endunless -%}
          {
            "id": {{ item.id | json }},
            "title": {{ item.title | json }},
            "url": {{ item.url | json }},
            "image": {{ item.featured_image | img_url: 'medium' | json }},
            "location": {{ location | json }}
          }
          {%- assign first_item = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  {%- endpaginate -%}
{%- endif -%}
